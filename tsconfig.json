{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["references/**/*.ts"]
}
